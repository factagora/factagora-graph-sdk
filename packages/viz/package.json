{
  "name": "@factagora/chatbot-viz",
  "version": "0.3.31",
  "description": "Factagora Chatbot 그래프/타임라인 시각화 컴포넌트 (React + tree-shaking)",
  "keywords": [
    "factagora",
    "visualization",
    "graph",
    "timeline",
    "react",
    "force-graph",
    "vis-timeline"
  ],
  "author": "Factagora Team",
  "license": "MIT",
  "packageManager": "pnpm@10.30.2",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./graph": {
      "import": {
        "types": "./dist/graph.d.ts",
        "default": "./dist/graph.js"
      },
      "require": {
        "types": "./dist/graph.d.cts",
        "default": "./dist/graph.cjs"
      }
    },
    "./timeline": {
      "import": {
        "types": "./dist/timeline.d.ts",
        "default": "./dist/timeline.js"
      },
      "require": {
        "types": "./dist/timeline.d.cts",
        "default": "./dist/timeline.cjs"
      }
    },
    "./chat": {
      "import": {
        "types": "./dist/chat.d.ts",
        "default": "./dist/chat.js"
      },
      "require": {
        "types": "./dist/chat.d.cts",
        "default": "./dist/chat.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@dagrejs/dagre": "^1.1.5",
    "@factagora/types": "workspace:*",
    "d3-force": "^3.0.0"
  },
  "peerDependencies": {
    "@xyflow/react": "^12.0.0",
    "lucide-react": ">=0.460.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "react-force-graph-2d": "^1.25.0",
    "vis-data": "^7.1.9 || ^8.0.0",
    "vis-timeline": "^7.7.3 || ^8.0.0",
    "zustand": "^5.0.0 || ^4.0.0"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.0.1",
    "@factagora/tsconfig": "workspace:*",
    "@storybook/addon-a11y": "^10.2.15",
    "@storybook/addon-docs": "^10.2.15",
    "@storybook/addon-onboarding": "^10.2.15",
    "@storybook/addon-vitest": "^10.2.15",
    "@storybook/react": "^10.2.15",
    "@storybook/react-vite": "^10.2.15",
    "@types/d3-force": "^3.0.10",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitest/browser-playwright": "^4.0.18",
    "@vitest/coverage-v8": "^4.0.18",
    "playwright": "^1.58.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "storybook": "^10.2.15",
    "tsup": "^8.3.5",
    "typescript": "^5.9.3",
    "vis-data": "^7.1.9",
    "vis-timeline": "^7.7.3",
    "vitest": "^4.0.18"
  },
  "publishConfig": {
    "access": "restricted",
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/factagora/factagora-graph-sdk.git",
    "directory": "packages/viz"
  }
}
